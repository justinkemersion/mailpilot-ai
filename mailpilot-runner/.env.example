# OpenAI (required for run / run-once / summarize)
OPENAI_API_KEY=sk-your-openai-key

# Gmail OAuth client JSON (required for add-account; path to Desktop client secrets)
GOOGLE_CREDENTIALS_FILE=/full/path/to/google_client_secrets.json

# --- MailPilot core ---
MAILPILOT_DB_PATH=./data/mailpilot.db
MAILPILOT_POLL_INTERVAL_SECONDS=300
MAILPILOT_LOG_LEVEL=INFO
MAILPILOT_OPENAI_MODEL=gpt-4.1-mini

# --- Optional: inbox noise / archiving (defaults off) ---
# MAILPILOT_ARCHIVE_SECURITY_NOISE=1   # Archive routine security notices; critical alerts stay important
# MAILPILOT_ARCHIVE_RECEIPTS=1         # Archive receipts/statements (same per-run caps as newsletters)

# --- Optional: safe senders (never spam; skip aggressive archive where rules apply) ---
# Comma-separated, case-insensitive
# MAILPILOT_SAFE_SENDER_DOMAINS=mycompany.com,bank.com
# MAILPILOT_SAFE_SENDERS=boss@example.com,billing@bank.com

# --- Optional: per-run safety caps ---
# MAILPILOT_MAX_ARCHIVES_PER_RUN=30
# MAILPILOT_MAX_SPAM_MARKS_PER_RUN=10
# MAILPILOT_MAX_LABEL_ACTIONS_PER_RUN=200
