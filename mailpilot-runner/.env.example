# OpenAI (required for classification)
OPENAI_API_KEY=sk-your-key-here

# Supabase — use the service role key only on trusted worker hosts (bypasses RLS).
# Same project as mailpilot-web; URL is like https://xxxx.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional tuning
MAILPILOT_POLL_INTERVAL_SECONDS=300
MAILPILOT_LOG_LEVEL=INFO
