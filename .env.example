# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Gmail OAuth
# Option 1: point to a Google OAuth client credentials JSON file
GOOGLE_CREDENTIALS_FILE=/full/path/to/google_client_secrets.json

# MailPilot
MAILPILOT_DB_PATH=./data/mailpilot.db
MAILPILOT_POLL_INTERVAL_SECONDS=300
MAILPILOT_LOG_LEVEL=INFO
MAILPILOT_OPENAI_MODEL=gpt-4.1-mini

# Optional: reduce inbox noise (defaults off to avoid hiding important messages)
# MAILPILOT_ARCHIVE_SECURITY_NOISE=1   # Archive routine security notices (2FA, app access, etc.); critical alerts stay important
# MAILPILOT_ARCHIVE_RECEIPTS=1        # Archive receipts/statements (same per-run limits as newsletters)